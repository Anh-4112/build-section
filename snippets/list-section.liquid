{% liquid
    assign section_st = section.settings
    assign show_product_count = section_st.show_product_count
%}

{% for block in section.blocks %}
    {% if block.type == 'list_collection' %}
        {% assign collection = block.settings.collection %}
        <div
            class="list-item{% if collection.url == blank %} not-allowed{% endif %} py-20 bor-bot bor-1"
            style="border-color: rgba(128, 128, 128, 0.2);{% if collection.image != blank %} --list-image-hover: url('{{ collection.image | image_url }}');{% endif %}"
        >
            <a class="list-link d-flex jc-between ai-center{% if collection.url == blank %} pointer-none{% endif %}" href="{{ collection.url | default: '#' }}">
                <span 
                    class="list-name typography-info"
                    product-count="{{ collection.products_count |  default: 0 }}"
                    show-product-count="{{ show_product_count | json }}"
                >
                    {{ collection.title |  default: 'Collection Name' }}
                </span>
                <span class="list-icon d-block content-fit rounded-50p overflow-hidden bor bor-1" style="border-color: rgba(128, 128, 128, 0.2);">
                    <span class="d-none d-md-flex content-center w-50 h-50">
                        <svg width="6" height="10" viewBox="0 0 6 10">
                            <use href="#icon-next"></use>
                        </svg>
                    </span>
                    <span class="d-block d-md-none w-60 h-60">
                        {% if collection.image != blank %}
                            <img 
                                class="img-cover"
                                src="{{ collection.image | image_url }}" 
                                alt="{{ collection.title }}"
                                width="100%"
                                height="100%" 
                            >
                        {% else %}
                            {% render 'image-clone' %}  
                        {% endif %}
                    </span>
                </span>
            </a>
        </div>
    {% endif %}
{% endfor %}