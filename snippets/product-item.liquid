{{ 'product-item.css' | asset_url | stylesheet_tag }}

{% liquid %}

<div class="product__item h-full">
    <a class="product-media wrapper-hover d-block h-full overflow-hidden relative" href="{{ product.url | default: '#' }}">
        {% if product.featured_image != blank %}
            <img 
                class="main-image hover-hidden img-cover d-block"
                src="{{ product.featured_image | image_url }}"
                alt="{{ product.title }}"
                width="100%" 
                height="100%"
            >
        {% else %}
            {% render 'image-clone' %}  
        {% endif %}
        {% if product.featured_image != blank %}
            <img 
                class="secondary-image hover-appear img-cover d-block absolute top-0 left-0 opacity-0"
                src="{{ product.media[1] | image_url }}"
                alt="{{ product.title }}"
                width="100%"
                height="100%"
            >
        {% endif %}
    </a>

</div>