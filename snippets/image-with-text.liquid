{% liquid
    assign block_st = block.settings

    assign inherit_color_scheme = block_st.inherit_color_scheme
    assign color_scheme = block_st.color_scheme
    assign width_block = block_st.width_block

    assign image_desktop = block_st.image_desktop
    assign image_mobile = block_st.image_mobile
%}

<div 
    class="block__image-with-text{% if inherit_color_scheme != true %} color-{{ color_scheme }} gradient{% endif %} f-custom"
    style="--f-custom: {{ width_block }};"
>
    <div class="block__image">
        {% if image_desktop != blank or image_mobile != blank %}
            <picture>
                {% if image_mobile != blank %}
                    <source media="(max-width: 767.98px)" class="img-cover" srcset="{{ image_mobile | image_url }}">
                {% endif %}
                <img class="img-cover" src="{{ image_desktop | default: image_mobile | image_url }}" alt="Image" width="100%" height="100%">
            </picture>
        {% else %}
            {% render 'image-clone' %}
        {% endif %}
    </div>
    <div class="block__text">
        Text content would go here
    </div>
</div>