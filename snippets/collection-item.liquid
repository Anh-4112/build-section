<div class="collection__item relative{% if collection.url == blank %} pointer-none{% endif %}">
    <div class="collection__item-media">
        <a class="collection-image" href="{{ collection.url }}">
            {% if collection.image != blank %}
                <img 
                    class="img-cover"
                    src="{{ collection.image | image_url }}" 
                    alt="{{ collection.title }}"
                    width="100%" 
                    height="100%" 
                >
            {% else %}
                {% render 'image-clone' %}  
            {% endif %}
        </a>
    </div>
    <div class="collection__item-info absolute left-7p bottom-7p">
        <a class="collection-name" href="{{ collection.url }}">
            {% if collection.title %}{{ collection.title }}{% else %}Collection Name{% endif %}
        </a>
    </div>
</div>