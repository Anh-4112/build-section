{% liquid
    assign section_st = section.settings
    assign ratio_image = section_st.ratio_image
        if ratio_image == 'adapt'
            assign ratio_image = ''
        elsif ratio_image == 'square'
            assign ratio_image = 'ratio-square'
        else ratio_image == 'portrait'
            assign ratio_image = 'ratio-portrait'
        endif
    assign position_content = section_st.position_content
    assign content_alignment = section_st.content_alignment
%}
<a class="collection__item d-block{% if position_content == 'overlay_image' %} relative{% endif %}{% if collection.url == blank %} not-allowed{% endif %}" href="{{ collection.url | default: '#' }}">
    <div class="collection__item-media {{ ratio_image }}">
        {% if collection.image != blank %}
            <img 
                class="img-cover"
                src="{{ collection.image | image_url }}" 
                alt="{{ collection.title }}"
                width="100%" 
                height="100%" 
            >
        {% else %}
            {% render 'image-clone' %}  
        {% endif %}
    </div>
    <div class="collection__item-info text-{{ content_alignment }}{% if position_content == 'overlay_image' %} absolute left-7p bottom-7p right-7p{% endif %}{% if position_content == 'below_image' %} mt-20{% endif %}">
        <span class="collection-name btn-link">
            {{ collection.title |  default: 'Collection Name' }}
        </span>
    </div>
</a>
