{% liquid
    assign section_st = section.settings
    assign block_st = block.settings

    assign inherit_color_scheme = block_st.inherit_color_scheme
    assign color_scheme = block_st.color_scheme
    assign width_block = block_st.width_block

    assign height_img_mobile = section_st.height_img_mobile
    assign height_img_desktop = section_st.height_img_desktop

    assign image_desktop = block_st.image_desktop
    assign image_mobile = block_st.image_mobile

    assign subheading_img_with_txt = block_st.subheading_img_with_txt
    assign heading_img_with_txt = block_st.heading_img_with_txt
    assign description_img_with_txt = block_st.description_img_with_txt
    assign btn_img_with_txt = block_st.btn_img_with_txt
    assign link_img_with_txt = block_st.link_img_with_txt
%}

<div
    class="block__image-with-text f-custom"
    style="--f-custom: {{ width_block }};"
    {{ block.shopify_attributes }}
>
    <div 
        class="block__image h-responsive" 
        style="--h-mobile: {{ height_img_mobile }}; --h-desktop: {{ height_img_desktop }};"
    >
        {% if image_desktop != blank or image_mobile != blank %}
            <picture class="h-full">
                {% if image_mobile != blank %}
                    <source media="(max-width: 767.98px)" class="img-cover" srcset="{{ image_mobile | image_url }}">
                {% endif %}
                <img class="img-cover" src="{{ image_desktop | default: image_mobile | image_url }}" alt="Image" width="100%" height="100%">
            </picture>
        {% else %}
            {% render 'image-clone' %}
        {% endif %}
    </div>
    <div class="block__content{% if inherit_color_scheme != true %} color-{{ color_scheme }} gradient{% endif %}">
        {% content_for 'blocks' %}
    
        {% if subheading_img_with_txt != blank %}
            <div class="block__subheading">
                {{ subheading_img_with_txt }}
            </div>
        {% endif %}

        {% comment %} {% if heading_img_with_txt != blank %}
            <div class="block__heading">
                {{ heading_img_with_txt }}
            </div>
        {% endif %} {% endcomment %}

        {% if description_img_with_txt != blank %}
            <div class="block__description">
                {{ description_img_with_txt }}
            </div>
        {% endif %}

        {% if btn_img_with_txt != blank %}
            <a href="{{ link_img_with_txt }}" class="block__button">
                {{ btn_img_with_txt }}
            </a>
        {% endif %}
    </div>
</div>

{%  schema  %}
{
    "name": "Media with content",
    "tag": null,
    "settings": [
        {
            "type": "checkbox",
            "id": "inherit_color_scheme",
            "label": "Inherit color scheme",
            "default": true
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color scheme",
            "default": "scheme-1",
            "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
        },
        {
            "type": "text",
            "id": "width_block",
            "label": "Width(%)",
            "default": "50",
            "info": "Only integer and decimal values are allowed"
        },

        {
            "type": "header",
            "content": "Image settings"
        },
        {
            "type": "image_picker",
            "id": "image_desktop",
            "label": "Image desktop"
        },
        {
            "type": "image_picker",
            "id": "image_mobile",
            "label": "Image mobile"
        },
        {
            "type": "header",
            "content": "Content settings"
        },
        {
            "type": "text",
            "id": "btn_img_with_txt",
            "label": "Button label",
            "default": "Button label"
        },
        {
            "type": "url",
            "id": "link_img_with_txt",
            "label": "Button link"
        }
    ],
    "blocks": [
        {
            "type": "heading"
        },
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "Media with content",
            "blocks": [
                {
                    "type": "heading"
                },
                {
                    "type": "text"
                }
            ]
        }
    ]
}
{% endschema %}