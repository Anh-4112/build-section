{% liquid
    assign block_st = block.settings

    assign text = block_st.text
    assign font_size = block_st.font_size
    assign font_weight = block_st.font_weight
    assign spacing_top = block_st.spacing_top
    assign spacing_bottom = block_st.spacing_bottom
%}

<div
    class="block__text fs-custom fw-custom mt-custom mb-custom"
    style="--fs-custom: {{ font_size }}; --fw-custom: {{ font_weight }}; --mt-custom: {{ spacing_top }}; --mb-custom: {{ spacing_bottom }};"
    {{ block.shopify_attributes }}
>
    {{ text | default: 'Text description' }}
</div>

{%  schema  %}
{
    "name": "Text description",
    "settings": [
        {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Text</p>"
        },
        {
            "type": "range",
            "id": "font_size",
            "label": "Font size",
            "default": 16,
            "min": 10,
            "max": 24,
            "step": 1
        },
        {
            "type": "range",
            "id": "font_weight",
            "label": "Font weight",
            "default": 400,
            "min": 100,
            "max": 900,
            "step": 100
        },
        {
            "type": "range",
            "id": "spacing_top",
            "label": "Spacing top",
            "default": 0,
            "min": 0,
            "max": 50,
            "step": 1
        },
        {
            "type": "range",
            "id": "spacing_bottom",
            "label": "Spacing bottom",
            "default": 0,
            "min": 0,
            "max": 50,
            "step": 1
        }
    ],
    "presets": [
        {
            "name": "Text description"
        }
    ]
}
{% endschema %}