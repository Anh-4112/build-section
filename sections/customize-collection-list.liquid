{% liquid
    assign theme_st = settings
    assign section_st = section.settings

    assign heading =  section_st.heading
    assign description =  section_st.description
%}

<section>
    <div>
        {% if heading != blank or description != blank %}
            {% render 'block-header',
               section: section
            %}
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Customize Collection List",
    "tag": "section",
    "settings": [
        {
            "type": "header",
            "content": "Header"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "richtext",
            "id": "subheading",
            "label": "Subheading"
        },
        {
            "type": "select",
            "id": "header_size",
            "label": "Header size",
            "default": "medium",
            "options": [
                {
                    "value": "small",
                    "label": "Small"
                },
                {
                    "value": "medium",
                    "label": "Medium"
                },
                {
                    "value": "large",
                    "label": "Large"
                }
            ]
        },
        {
            "type": "select",
            "id": "txt_align",
            "label": "Text Align",
            "default": "center",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "reverse-content",
            "label": "Reverse Content Order",
            "default": false
        }
    ],
    "presets": [
        {
            "name": "Customize Collection List"
        }
    ]
}
{% endschema %}