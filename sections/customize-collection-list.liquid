{% liquid
    assign section_st = section.settings
    assign blocks_st = block.settings

    assign color_scheme = section_st.color_scheme
    assign section_width = section_st.section_width
    assign section_pt = section_st.section_pt
    assign section_pb = section_st.section_pb

    assign heading =  section_st.heading
    assign description =  section_st.description
%}
{% capture style %}
    --section-pt: {{ section_pt }}; --section-pb: {{ section_pb }};
{% endcapture %}

<section class="section__py color-{{ color_scheme }} gradient" style="{{ style | strip }}">
    <div class="{{ section_width }}">
        {% if heading != blank or description != blank %}
            {% render 'block-header', section: section %}
        {% endif %}
        <div>
            <swiper-section
                class="swiper-section swiper relative"
                data-items-pc="{{ items_per_row_pc }}"
                data-items-mobile="{{ items_per_row_mobile }}"
                data-gap="{{ column_gap }}"
                data-infinite="{{ infinite_slide }}"
                data-auto="{{ auto_slide }}"
                data-interval="{{ interval_slide }}"
            >
                {% if check_icon %}
                    {% render 'swiper-icon' %}
                {% endif %}
            
                <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                        <div class="swiper-slide txt-no-select">
                            <div>
                                {% if blocks_st.author_image != blank %}
                                    <img 
                                        class="img-cover"
                                        src="{{ blocks_st.author_image | image_url }}" 
                                        alt="Image"
                                        width="100%" 
                                        height="100%" 
                                    >
                                {% else %}
                                    {% render 'image-clone' %}
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </swiper-section>
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Customize Collection List",
    "tag": "section",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Section color",
            "default": "scheme-1"
        },
        {
            "type": "select",
            "id": "section_width",
            "label": "Section width",
            "default": "defaul",
            "options": [
                {
                    "value": "defaul",
                    "label": "Defaul"
                },
                {
                    "value": "fluid-container",
                    "label": "Fluid Container"
                },
                {
                    "value": "stretch-width",
                    "label": "Stretch Width"
                },
                {
                    "value": "full-width",
                    "label": "Full Width"
                }
            ]
        },
        {
            "type": "header",
            "content": "Header"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
        },
        {
            "type": "richtext",
            "id": "subheading",
            "label": "Subheading",
            "default": "<p>Subheading</p>"
        },
        {
            "type": "select",
            "id": "header_size",
            "label": "Header size",
            "default": "medium",
            "options": [
                {
                    "value": "small",
                    "label": "Small"
                },
                {
                    "value": "medium",
                    "label": "Medium"
                },
                {
                    "value": "large",
                    "label": "Large"
                }
            ]
        },
        {
            "type": "select",
            "id": "txt_align",
            "label": "Text Align",
            "default": "center",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "reverse-content",
            "label": "Reverse content order",
            "default": false,
            "visible_if": "{{ section.settings.heading != blank and section.settings.subheading != blank }}"
        },


        {
            "type": "header",
            "content": "Section padding"
        },
        {
            "type": "range",
            "id": "section_pt",
            "label": "Top",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "section_pb",
            "label": "Bottom",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        }
    ],
    "blocks": [
        {
            "type": "carousel_collection",
            "name": "Carousel collection",
            "limit": 6,
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        },
        {
            "type": "list_collection",
            "name": "List collection",
            "limit": 6,
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Customize Collection List"
        }
    ]
}
{% endschema %}