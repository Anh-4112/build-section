{% liquid
    assign section_st = section.settings

    assign color_scheme = section_st.color_scheme
    assign section_width = section_st.section_width
    assign section_pt = section_st.section_pt
    assign section_pb = section_st.section_pb

    assign heading = section_st.heading
    assign subheading = section_st.subheading

    assign space_between = section_st.space_between
%}

{% capture style %}
    --section-pt: {{ section_pt }}; --section-pb: {{ section_pb }};
{% endcapture %}

<section class="section__multi-content section__py color-{{ color_scheme }} gradient" style="{{ style | strip }}">
    <div class="{{ section_width }}">
        {% if heading != blank or subheading != blank %}
            <div class="section__header">
                {% render 'header', section: section %}
            </div>
        {% endif %}
        <div class="content__multi-content header-spacing d-flex f-wrap gap-custom" style="--gap-custom: {{ space_between }};">
            {% content_for 'blocks' %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Multi Content",
    "tag": "section",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Section color",
            "default": "scheme-1"
        },
        {
            "type": "select",
            "id": "section_width",
            "label": "Section width",
            "default": "defaul",
            "options": [
                {
                    "value": "defaul",
                    "label": "Defaul"
                },
                {
                    "value": "fluid-container",
                    "label": "Fluid Container"
                },
                {
                    "value": "stretch-width",
                    "label": "Stretch Width"
                },
                {
                    "value": "full-width",
                    "label": "Full Width"
                }
            ]
        },
        {
            "type": "header",
            "content": "Header"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
        },
        {
            "type": "richtext",
            "id": "subheading",
            "label": "Subheading",
            "default": "<p>Subheading</p>"
        },
        {
            "type": "select",
            "id": "header_size",
            "label": "Header size",
            "default": "medium",
            "options": [
                {
                    "value": "small",
                    "label": "Small"
                },
                {
                    "value": "medium",
                    "label": "Medium"
                },
                {
                    "value": "large",
                    "label": "Large"
                }
            ]
        },
        {
            "type": "select",
            "id": "txt_align",
            "label": "Text Align",
            "default": "left",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "reverse_content",
            "label": "Reverse content order",
            "default": false,
            "visible_if": "{{ section.settings.heading != blank and section.settings.subheading != blank }}"
        },
        {
            "type": "header",
            "content": "Settings"
        },
        {
            "type": "range",
            "id": "space_between",   
            "label": "Gap between",
            "default": 15,
            "min": 5,
            "max": 30,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "height_img_mobile",   
            "label": "Height mobile",
            "default": 300,
            "min": 300,
            "max": 500,
            "step": 5,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "height_img_desktop",   
            "label": "Height desktop",
            "default": 500,
            "min": 500,
            "max": 800,
            "step": 10,
            "unit": "px"
        },

        {
            "type": "header",
            "content": "Section padding"
        },
        {
            "type": "range",
            "id": "section_pt",
            "label": "Top",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "section_pb",
            "label": "Bottom",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        }
    ],
    "blocks": [
        {
            "type": "_group-media-content"
        }
    ],
    "presets": [
        {
            "name": "Multi Content",
            "blocks": [
                {
                    "type": "_group-media-content",
                    "blocks": [
                        {
                            "type": "heading"
                        },
                        {
                            "type": "text"
                        }
                    ]
                },
                {
                    "type": "_group-media-content",
                    "blocks": [
                        {
                            "type": "heading"
                        },
                        {
                            "type": "text"
                        }
                    ]
                }
            ]
        }
    ]
}
{% endschema %}