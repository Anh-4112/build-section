{% liquid
    assign section_st = section.settings

    assign color_scheme = section_st.color_scheme
    assign section_width = section_st.section_width
    assign section_pt = section_st.section_pt
    assign section_pb = section_st.section_pb

    assign heading = section_st.heading
    assign subheading = section_st.subheading
%}

{% capture style %}
    --section-pt: {{ section_pt }}; --section-pb: {{ section_pb }};
{% endcapture %}

<section class="section__product-carousel section__py color-{{ color_scheme }} gradient" style="{{ style | strip }}">
    <div class="{{ section_width }}">
        {% if heading != blank or subheading != blank %}
            <div class="section__header">
                {% render 'header', section: section %}
            </div>
        {% endif %}
        <div class="content__product-carousel mt-20">
            {% 
                render 'swiper-section', 
                section_id: 'product-carousel',
                item_type: 'product',
                section: section,
                blocks: section_st.collection.products
            %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Product Carousel",
    "tag": "section",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Section color",
            "default": "scheme-1"
        },
        {
            "type": "select",
            "id": "section_width",
            "label": "Section width",
            "default": "defaul",
            "options": [
                {
                    "value": "defaul",
                    "label": "Defaul"
                },
                {
                    "value": "fluid-container",
                    "label": "Fluid Container"
                },
                {
                    "value": "stretch-width",
                    "label": "Stretch Width"
                },
                {
                    "value": "full-width",
                    "label": "Full Width"
                }
            ]
        },
        {
            "type": "header",
            "content": "Header"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
        },
        {
            "type": "richtext",
            "id": "subheading",
            "label": "Subheading",
            "default": "<p>Subheading</p>"
        },
        {
            "type": "select",
            "id": "header_size",
            "label": "Header size",
            "default": "medium",
            "options": [
                {
                    "value": "small",
                    "label": "Small"
                },
                {
                    "value": "medium",
                    "label": "Medium"
                },
                {
                    "value": "large",
                    "label": "Large"
                }
            ]
        },
        {
            "type": "select",
            "id": "txt_align",
            "label": "Text Align",
            "default": "left",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "reverse_content",
            "label": "Reverse content order",
            "default": false,
            "visible_if": "{{ section.settings.heading != blank and section.settings.subheading != blank }}"
        },

        {
            "type": "header",
            "content": "Carousel settings"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
        },
        {
            "type": "checkbox",
            "id": "check_icon",
            "label": "Show next/back",
            "default": true
        },
        {
            "type": "range",
            "id": "items_per_row_pc",
            "label": "Items per row desktop",
            "default": 4,
            "min": 4,
            "max": 6,
            "step": 1
        },
        {
            "type": "range",
            "id": "items_per_row_mobile",
            "label": "Items per row mobile",
            "default": 1,
            "step": 0.5,
            "min": 1,
            "max": 2
        },
        {
            "type": "range",
            "id": "column_gap",
            "label": "Column gap",
            "default": 15,
            "min": 5,
            "max": 30,
            "step": 1,
            "unit": "px"
        },

        {
            "type": "header",
            "content": "Section padding"
        },
        {
            "type": "range",
            "id": "section_pt",
            "label": "Top",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "section_pb",
            "label": "Bottom",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        }
    ],
    "presets": [
        {
            "name": "Product Carousel"
        }
    ]
}
{% endschema %}