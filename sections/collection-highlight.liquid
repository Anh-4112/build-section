{{ 'collection-highlight.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection-highlight.js' | asset_url }}" defer="defer"></script>

{% liquid
    assign section_st = section.settings

    assign color_scheme = section_st.color_scheme
    assign section_width = section_st.section_width
    assign section_pt = section_st.section_pt
    assign section_pb = section_st.section_pb

    assign heading = section_st.heading
    assign subheading = section_st.subheading

    assign show_carousel = section_st.show_carousel
    assign show_list = section_st.show_list
%}

{% capture style %}
    --section-pt: {{ section_pt }}; --section-pb: {{ section_pb }};
{% endcapture %}

<section class="section__py color-{{ color_scheme }} gradient" style="{{ style | strip }}">
    <div class="{{ section_width }}">
        {% if heading != blank or subheading != blank %}
            <div class="section__header d-md-none">
                {% render 'header', section: section %}
            </div>
        {% endif %}
        <div class="section__collection-highlight d-md-flex gap-30 h-fit-content mt-20 mt-md-0">
            {% if show_carousel == true %}
                <div class="collection-highlight--carousel f-1 min-w-0 my-auto h-fit-content">
                    {% assign carousel_collection = section.blocks | where: 'type', 'carousel_collection' %}
                    {%
                        render 'swiper-section',
                        section: section,
                        section_type: 'collection-highlight',
                        item_type: 'collection',
                        blocks_type: carousel_collection
                    %}
                </div>
            {% endif %}
            {% if heading != blank or subheading != blank or show_list == true %}
                <div class="collection-highlight--list-wrapper f-1 min-w-0 my-auto h-fit-content d-flex column gap-12">
                    {% if heading != blank or subheading != blank %}
                        <div class="section__header pl-md-69 pt-md-42 d-none d-md-block">
                            {% render 'header', section: section %}
                        </div>
                    {% endif %}
                    {% if show_list == true %}
                        <div class="collection-highlight--list pl-md-69 f-1">
                            {% render 'list-section', section: section %}
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Collection Highlight",
    "tag": "section",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Section color",
            "default": "scheme-1"
        },
        {
            "type": "select",
            "id": "section_width",
            "label": "Section width",
            "default": "defaul",
            "options": [
                {
                    "value": "defaul",
                    "label": "Defaul"
                },
                {
                    "value": "fluid-container",
                    "label": "Fluid Container"
                },
                {
                    "value": "stretch-width",
                    "label": "Stretch Width"
                },
                {
                    "value": "full-width",
                    "label": "Full Width"
                }
            ]
        },
        {
            "type": "header",
            "content": "Header"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
        },
        {
            "type": "richtext",
            "id": "subheading",
            "label": "Subheading",
            "default": "<p>Subheading</p>"
        },
        {
            "type": "select",
            "id": "header_size",
            "label": "Header size",
            "default": "medium",
            "options": [
                {
                    "value": "small",
                    "label": "Small"
                },
                {
                    "value": "medium",
                    "label": "Medium"
                },
                {
                    "value": "large",
                    "label": "Large"
                }
            ]
        },
        {
            "type": "select",
            "id": "txt_align",
            "label": "Text Align",
            "default": "left",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "reverse_content",
            "label": "Reverse content order",
            "default": false,
            "visible_if": "{{ section.settings.heading != blank and section.settings.subheading != blank }}"
        },

        {
            "type": "checkbox",
            "id": "show_product_count",
            "label": "Show product count",
            "default": false
        },

        {
            "type": "header",
            "content": "Collection carousel settings"
        },
        {
            "type": "checkbox",
            "id": "show_carousel",
            "label": "Show carousel",
            "default": true
        },
        {
            "type": "checkbox",
            "id": "check_icon",
            "label": "Show next/back",
            "default": true,
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },
        {
            "type": "range",
            "id": "items_per_row_pc",
            "label": "Items per row desktop",
            "default": 2,
            "min": 1,
            "max": 3,
            "step": 1,
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },
        {
            "type": "range",
            "id": "items_per_row_mobile",
            "label": "Items per row mobile",
            "default": 1,
            "step": 0.5,
            "min": 1,
            "max": 2,
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },
        {
            "type": "range",
            "id": "column_gap",
            "label": "Column gap",
            "default": 15,
            "min": 5,
            "max": 30,
            "step": 1,
            "unit": "px",
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },
        {
            "type": "select",
            "id": "ratio_image",
            "label": "Ratio",
            "default" : "adapt",
            "options": [
                {
                    "value": "adapt",
                    "label": "Adapt to image"   
                },
                {
                    "value": "square",
                    "label": "Square (1:1)"
                },
                {
                    "value": "portrait",
                    "label": "Portrait (3:4)"
                }
            ],
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },
        {
            "type": "select",
            "id": "position_content",
            "label": "Position content",
            "default": "overlay_image",
            "options": [
                {
                    "value": "overlay_image",
                    "label": "Overlay image"
                },
                {
                    "value": "below_image",
                    "label": "Below image"
                }
            ],
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },
        {
            "type": "select",
            "id": "content_alignment",
            "label": "Content alignment",
            "default": "left",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                }
            ],
            "visible_if": "{{ section.settings.show_carousel == true }}"
        },

        {
            "type": "header",
            "content": "Collection list settings"
        },
        {
            "type": "checkbox",
            "id": "show_list",
            "label": "Show list",
            "default": true
        },

        {
            "type": "header",
            "content": "Section padding"
        },
        {
            "type": "range",
            "id": "section_pt",
            "label": "Top",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "section_pb",
            "label": "Bottom",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        }
    ],
    "blocks": [
        {
            "type": "carousel_collection",
            "name": "Carousel collection",
            "limit": 6,
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        },
        {
            "type": "list_collection",
            "name": "List collection",
            "limit": 6,
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Collection Highlight",
            "blocks": [
                {
                    "type": "carousel_collection"
                },
                {
                    "type": "carousel_collection"
                },
                {
                    "type": "carousel_collection"
                },
                {
                    "type": "carousel_collection"
                },
                {
                    "type": "list_collection"
                },
                {
                    "type": "list_collection"
                },
                {
                    "type": "list_collection"
                },
                {
                    "type": "list_collection"
                }
            ]
        }
    ]
}
{% endschema %}