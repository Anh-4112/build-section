{% liquid
    assign section_st = section.settings

    assign color_scheme = section_st.color_scheme
    assign section_width = section_st.section_width
    assign section_pt = section_st.section_pt
    assign section_pb = section_st.section_pb

    assign heading = section_st.heading
    assign subheading = section_st.subheading

    assign show_carousel = section_st.show_carousel
    assign show_list = section_st.show_list
%}
{% capture style %}
    --section-pt: {{ section_pt }}; --section-pb: {{ section_pb }};
{% endcapture %}

<section class="section__py color-{{ color_scheme }} gradient" style="{{ style | strip }}">
    <div class="{{ section_width }}">
        <div class="section__collection-highlight d-grid gap-10{% if heading != blank or subheading != blank %} grid-1x3{% else %} grid-1x2{% endif %}">
            {% if heading != blank or subheading != blank %}
                <div class="collection-highlight--header min-w-0" style="grid-column: 1/2; grid-row: 1/2;">
                    {% render 'block-header', section: section %}
                </div>
            {% endif %}
            {% if show_carousel == true %}
                <div class="collection-highlight--carousel min-w-0" style="grid-column: 1/2; grid-row: 2/3;">
                    {% render 'swiper-section', section: section %}
                </div>
            {% endif %}
            {% if show_list == true %}
                <div class="collection-highlight--list min-w-0" style="grid-column: 1/2; grid-row: 3/4;">
                    {% render 'list-section', section: section %}
                </div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Collection Highlight",
    "tag": "section",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Section color",
            "default": "scheme-1"
        },
        {
            "type": "select",
            "id": "section_width",
            "label": "Section width",
            "default": "defaul",
            "options": [
                {
                    "value": "defaul",
                    "label": "Defaul"
                },
                {
                    "value": "fluid-container",
                    "label": "Fluid Container"
                },
                {
                    "value": "stretch-width",
                    "label": "Stretch Width"
                },
                {
                    "value": "full-width",
                    "label": "Full Width"
                }
            ]
        },
        {
            "type": "header",
            "content": "Header"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
        },
        {
            "type": "richtext",
            "id": "subheading",
            "label": "Subheading",
            "default": "<p>Subheading</p>"
        },
        {
            "type": "select",
            "id": "header_size",
            "label": "Header size",
            "default": "medium",
            "options": [
                {
                    "value": "small",
                    "label": "Small"
                },
                {
                    "value": "medium",
                    "label": "Medium"
                },
                {
                    "value": "large",
                    "label": "Large"
                }
            ]
        },
        {
            "type": "select",
            "id": "txt_align",
            "label": "Text Align",
            "default": "center",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "reverse-content",
            "label": "Reverse content order",
            "default": false,
            "visible_if": "{{ section.settings.heading != blank and section.settings.subheading != blank }}"
        },

        {
            "type": "header",
            "content": "Collection carousel settings"
        },
        {
            "type": "checkbox",
            "id": "show_carousel",
            "label": "Show carousel",
            "default": true
        },
        {
            "type": "range",
            "id": "items_per_row_pc",
            "label": "Items per row desktop",
            "default": 2,
            "min": 1,
            "max": 3,
            "step": 1
        },
        {
            "type": "range",
            "id": "items_per_row_mobile",
            "label": "Items per row mobile",
            "default": 1,
            "step": 0.5,
            "min": 1,
            "max": 2
        },
        {
            "type": "range",
            "id": "column_gap",
            "label": "Column gap",
            "default": 15,
            "min": 0,
            "max": 50,
            "step": 1,
            "unit": "px"
        },

        {
            "type": "header",
            "content": "Collection list settings"
        },
        {
            "type": "checkbox",
            "id": "show_list",
            "label": "Show list",
            "default": true
        },

        {
            "type": "header",
            "content": "Section padding"
        },
        {
            "type": "range",
            "id": "section_pt",
            "label": "Top",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "section_pb",
            "label": "Bottom",
            "default": 50,
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px"
        }
    ],
    "blocks": [
        {
            "type": "carousel_collection",
            "name": "Carousel collection",
            "limit": 6,
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        },
        {
            "type": "list_collection",
            "name": "List collection",
            "limit": 6,
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Collection Highlight"
        }
    ]
}
{% endschema %}